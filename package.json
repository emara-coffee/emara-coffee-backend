{
  "name": "emara-coffee-backend",
  "version": "1.0.0",
  "description": "MERN Stack Backend with Multi-Role Authentication",
  "main": "dist/server.js",
  "scripts": {
    "start": "NODE_ENV=production node dist/server.js",
    "dev": "NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "build:force": "tsc --noEmit false --skipLibCheck true --skipDefaultLibCheck true --noErrorTruncation true --pretty false && tsc-alias",
    "start:dev": "NODE_ENV=development ts-node src/server.ts",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "build": "tsc && tsc-alias",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "db:generate": "NODE_ENV=development npx drizzle-kit generate --config=src/configs/drizzle.config.ts",
    "db:push": "NODE_ENV=development npx drizzle-kit push --config=src/configs/drizzle.config.ts",
    "db:migrate": "NODE_ENV=development npx drizzle-kit migrate --config=src/configs/drizzle.config.ts",
    "db:seed": "NODE_ENV=development ts-node src/utils/seed/index.ts",
    "db:studio": "NODE_ENV=development drizzle-kit studio",
    "db:destroy": "NODE_ENV=development ts-node src/utils/dbDestroy.ts",
    "db:migrate:prod": "node dist/utils/migrate.js",
    "seed": "NODE_ENV=development ts-node src/utils/seed/index.ts",
    "seed:destroy": "NODE_ENV=development ts-node src/utils/seed/index.ts -d"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "mongodb",
    "redis",
    "jwt",
    "authentication"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/lib-storage": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@clickhouse/client": "^1.16.0",
    "amqplib": "^0.10.9",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.4",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "razorpay": "^2.9.6",
    "redis": "^5.11.0",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.1",
    "@types/pg": "^8.20.0",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "jest": "^30.1.3",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
